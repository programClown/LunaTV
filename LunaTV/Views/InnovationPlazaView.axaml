<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="LunaTV.Views.InnovationPlazaView"
    x:DataType="vm:InnovationPlazaViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LunaTV.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="10">
        <Button Command="{Binding PlayVideoCommand}" Content="点我放电影" />
        <Button Command="{Binding TestWindowCommand}" Content="点我测试" />
    </StackPanel>

</UserControl>