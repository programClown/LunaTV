<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="LunaTV.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ui:NavigationView PaneDisplayMode="Left" x:Name="NaviView">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="Menu Item1"
                    IconSource="{StaticResource BmpIcon}"
                    Tag="SamplePage1" />
                <ui:NavigationViewItem
                    Content="Menu Item2"
                    IconSource="Save"
                    Tag="SamplePage2" />
                <ui:NavigationViewItem
                    Content="Menu Item3"
                    IconSource="Refresh"
                    Tag="SamplePage3" />
                <ui:NavigationViewItem
                    Content="Menu Item4"
                    IconSource="Download"
                    Tag="SamplePage4" />
            </ui:NavigationView.MenuItems>
        </ui:NavigationView>
    </Grid>

</UserControl>
